# OpenRouter API key — used for all LLM calls (Claude models via OpenRouter).
# Get one at https://openrouter.ai/keys
# (For backward compatibility the code also accepts this under ANTHROPIC_API_KEY.)
OPENROUTER_API_KEY=

# OpenAI API key — required only for --tts openai (uses gpt-4o-mini-tts directly).
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=
